rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /queries/{queryId} {
      // Allow users to read and create only their own queries
      allow read, create: if request.auth != null && request.auth.uid == resource.data.userId;

      // Allow create if they are setting the userId correctly
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;

      // Disallow all other access
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
